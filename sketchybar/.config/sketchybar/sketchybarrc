# Minimal dark color scheme
BLACK=0xff1a1b26
DARK_GRAY=0xff24283b
MID_GRAY=0xff414868
LIGHT_GRAY=0xff565f89
WHITE=0xffa9b1d6

# Neutral accent colors
ACCENT=0xff7aa2f7
ACTIVE_BG=0xff7aa2f7
BAR_COLOR=0x00000000
TRANSPARENT=0x00000000

PLUGIN_DIR="$CONFIG_DIR/plugins"

# Bar configuration - transparent to show islands only
sketchybar --bar height=30        \
                 margin=12        \
                 y_offset=0       \
                 padding_left=10  \
                 padding_right=10 \
                 color=$BAR_COLOR

# Default settings - minimal and dark
default=(
  background.color=$DARK_GRAY
  background.corner_radius=0
  background.border_width=0
  background.height=26
  background.padding_left=0
  background.padding_right=0
  icon.font="Hack Nerd Font:Bold:14.0"
  label.font="Hack Nerd Font:Bold:13.0"
  icon.color=$WHITE
  label.color=$WHITE
  icon.padding_left=10
  icon.padding_right=10
  label.padding_left=0
  label.padding_right=10
  y_offset=0
)

sketchybar --default "${default[@]}"

sketchybar --add event aerospace_workspace_change

# Aerospace workspaces - connected without gaps
order=(1 2 3 q w e)
existing=($(aerospace list-workspaces --all))
first=true
for sid in "${order[@]}"; do
    if [[ " ${existing[*]} " == *" $sid "* ]]; then
        # First item gets left corner radius, last gets right corner radius
        if [ "$first" = true ]; then
            corner_radius="background.corner_radius=0"
            padding_left="background.padding_left=0"
            first=false
        else
            corner_radius="background.corner_radius=0"
            padding_left="background.padding_left=0"
        fi
        
        sketchybar --add item space.$sid left \
            --subscribe space.$sid aerospace_workspace_change \
            --set space.$sid \
                icon="$sid" \
                background.color=$DARK_GRAY \
                $corner_radius \
                $padding_left \
                background.padding_right=0 \
                icon.padding_left=10 \
                icon.padding_right=0 \
                click_script="aerospace workspace $sid" \
                script="$CONFIG_DIR/plugins/aerospace.sh $sid"
    fi
done

# Apply right corner radius to the last workspace item
for sid in "${order[@]}"; do
    if [[ " ${existing[*]} " == *" $sid "* ]]; then
        sketchybar --set space.$sid background.corner_radius=0
        break
    fi
done

# Front app - separate island with left margin
sketchybar --add item front_app left \
           --set front_app \
                background.color=$DARK_GRAY \
                background.corner_radius=0 \
                background.padding_left=0 \
                icon.drawing=off \
                label.padding_left=12 \
                label.padding_right=12 \
                script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

# Right side items - connected together as one island
# Start with date (leftmost of right group)
sketchybar --add item date right \
           --set date \
                update_freq=20 \
                icon=󰸗 \
                background.color=$DARK_GRAY \
                background.corner_radius=0 \
                icon.padding_left=12 \
                icon.padding_right=8 \
                label.padding_right=8 \
                background.padding_right=0 \
                script="$PLUGIN_DIR/date.sh"

# Volume - middle item, no gaps
sketchybar --add item volume right \
           --set volume \
                background.color=$DARK_GRAY \
                background.corner_radius=0 \
                icon.padding_left=8 \
                icon.padding_right=8 \
                label.padding_left=0 \
                label.padding_right=8 \
                background.padding_left=1 \
                background.padding_right=1 \
                script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change

# CPU - rightmost item with right corner radius
sketchybar --add item cpu right \
           --set cpu \
                icon= \
                update_freq=3 \
                background.color=$DARK_GRAY \
                background.corner_radius=0 \
                icon.padding_left=8 \
                icon.padding_right=8 \
                label.padding_left=0 \
                label.padding_right=12 \
                background.padding_left=0 \
                script="$PLUGIN_DIR/cpu.sh"

sketchybar --update
